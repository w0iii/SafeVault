{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "IdentityConnection": "Data Source=safevault.identity.db",
    "SearchConnection": "Data Source=safevault.search.db"
  },
  "Jwt": {
    "Issuer": "SafeVault",
    "Audience": "SafeVaultUsers",
    "Key": "REPLACE_WITH_A_LONG_RANDOM_SECRET_LOADED_FROM_ENV_OR_SECRET_MANAGER",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}
